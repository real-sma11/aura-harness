# =============================================================================
# aura-harness environment configuration
# =============================================================================
#
# All LLM traffic is routed through aura-router (the AURA proxy) using a
# per-request JWT. There is no direct-provider path; this file only
# documents knobs that still mean something for proxy routing.

# URL of the aura-router service.
AURA_ROUTER_URL=https://aura-router.onrender.com

# Optional: JWT for terminal/CLI sessions. WebSocket clients normally
# provide their own on `RuntimeRequest.auth_jwt`. Leave unset and run
# `aura login` instead.
# AURA_ROUTER_JWT=

# -- E2E integration tests -----------------------------------------------------
# Credentials for zOS login (used to obtain a JWT for proxy API tests).
# E2E_ZOS_EMAIL=
# E2E_ZOS_PASSWORD=
# Optional: override bind address for the test server (default: 127.0.0.1:0).
# E2E_BIND_ADDR=127.0.0.1:0

# -- Shared --------------------------------------------------------------------
# Default model to send to the router. The legacy AURA_ANTHROPIC_MODEL
# name is still read as a fallback for one release cycle.
# AURA_DEFAULT_MODEL=claude-opus-4-6
# AURA_MODEL_TIMEOUT_MS=60000
# AURA_DATA_DIR=./aura_data
# Override the default per-user node data dir when you want a repo-local store.

# -- LLM reliability / proactive body trimming -------------------------------
# Maximum serialised `/v1/messages` body size, in bytes. When > 0 and the
# request body exceeds this cap, aura-reasoner shrinks the body in-place
# before forwarding to the aura-router edge:
#   1. truncate the largest text / `tool_result` payload in the last user
#      message,
#   2. if still over the cap, drop oldest non-system message pairs and
#      re-truncate,
#   3. as a last resort, collapse the conversation down to a single
#      placeholder user turn carrying the latest user text.
# The cap is the harness's first line of defence against the managed
# router's body-size WAF rules; the value should sit well below the
# observed Cloudflare cliff but generously above a typical multi-turn
# transcript. Default `524288` (512 KiB). Set to `0` to disable
# proactive trimming entirely (legacy behaviour).
# AURA_LLM_EMERGENCY_BODY_CAP_BYTES=524288

# On a Cloudflare 403 the harness shrinks the body cap by 25% and
# retries up to this many times before surfacing the error to the
# caller. Each retry deterministically converges on a body the edge
# will accept rather than burning the retry budget on duplicate 403s.
# Default `3`. Set to `0` to disable 403 retries entirely.
# AURA_LLM_CLOUDFLARE_MAX_RETRIES=3

# -- Node HTTP/WS authentication ---------------------------------------------
# The aura-node router ships with its `Authorization: Bearer` gate OFF by
# default. Set AURA_NODE_REQUIRE_AUTH=1 (or true) to re-enable the full
# shared-secret flow: a 32-byte hex token is minted / read from
# $AURA_DATA_DIR/auth_token, every non-/health route requires it, and the
# embedded TUI API server prints the token to stderr on startup. Pair it
# with AURA_NODE_AUTH_TOKEN to pin the value (e.g. for CI).
# AURA_NODE_REQUIRE_AUTH=0
# AURA_NODE_AUTH_TOKEN=

# -- Sealed state-at-rest (Swarm TEE / confidential VMs) -----------------------
# When AURA_STATE_ENCRYPTION=sealed, the node fetches a 256-bit DEK before
# opening any state and AES-256-GCM-seals every content-bearing store value.
# If no DEK is obtainable within AURA_DEK_FETCH_TIMEOUT_SECS the node refuses
# to start — sealed mode never falls back to plaintext. Leave everything here
# unset for the legacy plaintext behaviour.
# AURA_STATE_ENCRYPTION=sealed
# Per-agent DEK key id (set by the aura-swarm control plane).
# AURA_STATE_KEY_ID=swarm/agents/{agent_id}/state-key
# In-guest confidential-data-hub resource endpoint (CoCo guests).
# AURA_CDH_URL=http://127.0.0.1:8006
# Dev mode: read/generate the DEK from a local key file instead of the CDH.
# A random key (64 hex chars, mode 0600 on Unix) is created on first boot.
# AURA_STATE_KEY_FILE=./aura_data/state.key
# Bound on the DEK fetch retry window (seconds, default 120).
# AURA_DEK_FETCH_TIMEOUT_SECS=120
